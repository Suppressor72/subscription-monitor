# Optional shared secret for the web UI / API (recommended on LAN)
# SUBMON_TOKEN=change-me

# Bind address (default 0.0.0.0:8787)
# SUBMON_HOST=0.0.0.0
# SUBMON_PORT=8787

# Optional custom data dir / env file
# SUBMON_DATA=./data
# SUBMON_ENV=./.env

# --- Z.ai Coding Plan ---
# GLM_API_KEY=
# ZAI_API_KEY=

# --- Cursor (if not reading Chrome cookies) ---
# CURSOR_SESSION_TOKEN=
# CURSOR_CHROME_COOKIES=~/.config/google-chrome/Default/Cookies
